# User and Group IDs (use `id -u` and `id -g` to get your current user's IDs)
PUID=1000
PGID=1000

# Timezone
TZ=Europe/Paris

# Media folder path (absolute path on your host)
# Example: /datadisk/Media or /home/user/Media
MEDIA_PATH=/datadisk/Media

# Transmission credentials
TRANSMISSION_USER=admin
TRANSMISSION_PASS=change_this_password

# MySQL Database settings
MYSQL_ROOT_PASSWORD=secure_root_password_here
MYSQL_DATABASE=wordpress
MYSQL_USER=wordpress
MYSQL_PASSWORD=secure_wordpress_password_here

# Domain Configuration
# For local development, use .local domains (e.g., jellyfin.local)
# For production, use your actual domain (e.g., jellyfin.example.com)
DOMAIN_BASE=local
DOMAIN_JELLYFIN=jellyfin.${DOMAIN_BASE}
DOMAIN_TRANSMISSION=transmission.${DOMAIN_BASE}
DOMAIN_WORDPRESS=wordpress.${DOMAIN_BASE}
DOMAIN_NPM=npm.${DOMAIN_BASE}

# SSL Configuration
# Set to 'true' to automatically configure Let's Encrypt SSL (requires public domain)
# Set to 'false' for local development
ENABLE_SSL=false
LETSENCRYPT_EMAIL=admin@example.com

# Nginx Proxy Manager Admin Credentials (change after first login)
NPM_ADMIN_EMAIL=admin@example.com
NPM_ADMIN_PASSWORD=changeme

# Jellyfin Configuration
# Admin user credentials for initial setup
JELLYFIN_ADMIN_USER=admin
JELLYFIN_ADMIN_PASSWORD=

# Jellyfin Libraries — format: DisplayName:type:SubFolder (relative to MEDIA_PATH), comma-separated
# Available types: movies, tvshows, music, books, photos
JELLYFIN_LIBRARIES="Movies:movies:Movies,TV Shows:tvshows:TvShows,Kids Movies:movies:KidsMovies,Kids Shows:tvshows:KidsTvShows"
