# User and Group IDs (use `id -u` and `id -g` to get your current user's IDs)
PUID=1000
PGID=1000

# Timezone
TZ=Europe/Paris

# Media folder path (absolute path on your host)
# Example: /datadisk/Media or /home/user/Media
# Will be mounted to the Jellyfin and WordPress containers for media access and storage into the folder "downloads"
MEDIA_PATH=/datadisk/Media

# Transmission credentials
TRANSMISSION_USER=admin
TRANSMISSION_PASS=change_this_password

# MySQL Database settings
MYSQL_ROOT_PASSWORD=secure_root_password_here
MYSQL_DATABASE=wordpress
MYSQL_USER=wordpress
MYSQL_PASSWORD=secure_wordpress_password_here

# Domain Configuration
# For local development, use .local domains (e.g., jellyfin.local)
# For production, use your actual domain (e.g., jellyfin.example.com)
DOMAIN_BASE=local
DOMAIN_JELLYFIN=jellyfin.${DOMAIN_BASE}
DOMAIN_TRANSMISSION=transmission.${DOMAIN_BASE}
DOMAIN_WORDPRESS=wordpress.${DOMAIN_BASE}

# SSL Configuration
# Set to 'true' to automatically configure Let's Encrypt SSL (requires public domain)
# Set to 'false' for local development (Caddy will disable HTTPS)
ENABLE_SSL=false
LETSENCRYPT_EMAIL=admin@example.com

# Jellyfin Configuration
# Admin user credentials for initial setup
JELLYFIN_ADMIN_USER=admin
JELLYFIN_ADMIN_PASSWORD=

# WordPress Configuration
# Admin credentials and site metadata used by the setup script via WP-CLI
WP_ADMIN_USER=admin
WP_ADMIN_PASSWORD=change_this_wp_password
WP_ADMIN_EMAIL=admin@example.com
WP_SITE_TITLE=My WordPress Site

# WordPress HTTP Basic Auth (optional — leave empty to disable)
# Protects the entire WordPress site with a login prompt at the proxy level
WP_HTTP_AUTH_USER=
WP_HTTP_AUTH_PASSWORD=

# Jellyfin Libraries — format: DisplayName:type:SubFolder (relative to MEDIA_PATH), comma-separated
# Available types: movies, tvshows, music, books, photos
JELLYFIN_LIBRARIES="Movies:movies:Movies,TV Shows:tvshows:TvShows,Kids Movies:movies:KidsMovies,Kids Shows:tvshows:KidsTvShows"

# All-in-one-download plugin — absolute paths used by the plugin to store downloaded files
# These should be subdirectories of MEDIA_PATH to ensure proper volume mapping and permissions
# These are set as WordPress site options (movie_directory / tv_show_directory) after plugin install
AIO_MOVIE_DIRECTORY=downloads/Movies
AIO_TV_SHOW_DIRECTORY=downloads/TvShows

# All-in-one-download-torr9 plugin credentials
# Retrieve these from your Torr9 account settings
TORR9_API_KEY=
TORR9_FULL_TOKEN=

# All-in-one-download-c411 plugin credentials
# Retrieve your API key from https://c411.org (account settings)
C411_API_KEY=

# WordPress Cron — set to true to disable the built-in WP-Cron and delegate to Ofelia
# Leave false (or unset) to keep the native WordPress cron enabled
DISABLE_WP_CRON=false
